@{
    Layout = null;
    ViewData["Title"] = "Database Versioning | PAS";
}
@model object

<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>@ViewData["Title"]</title>
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700;800&display=swap" rel="stylesheet">
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.0.0/css/all.min.css">
    <link rel="stylesheet" href="~/css/site.css">
</head>
<body>
    <nav class="glass-nav">
        <div class="nav-container">
            <div class="logo"><i class="fas fa-server"></i><span>PAS | WebMaster Portal</span></div>
            <div class="user-info">
                <a href="/Auth/Logout" style="color:white; background:rgba(255,255,255,0.2); padding:8px 20px; border-radius:25px;">
                    <i class="fas fa-sign-out-alt"></i> Logout
                </a>
            </div>
        </div>
    </nav>

    <div class="main-container">
        <a href="/WebMaster/Dashboard" style="color:#00d2ff; text-decoration:none; display:inline-block; margin-bottom:1rem;">
            <i class="fas fa-arrow-left"></i> Back to Dashboard
        </a>

        <div class="welcome-card">
            <h1 class="welcome-title"><i class="fas fa-database"></i> Database Versioning</h1>
            <p class="welcome-subtitle">Entity Framework Core Migrations — schema change history</p>
        </div>

        <!-- Summary Cards -->
        <div class="stats-grid" style="grid-template-columns: repeat(2, 1fr); margin-bottom:2rem;">
            <div class="stat-card" style="text-align:center;">
                <div class="stat-icon" style="background:linear-gradient(135deg,#28a745,#20c997); margin:0 auto 1rem auto;">
                    <i class="fas fa-check-circle"></i>
                </div>
                <div class="stat-value" style="color:#28a745;">@(((List<string>)ViewBag.AppliedMigrations).Count)</div>
                <div class="stat-label">Applied Migrations</div>
            </div>
            <div class="stat-card" style="text-align:center;">
                <div class="stat-icon" style="background:linear-gradient(135deg,#ffc107,#fd7e14); margin:0 auto 1rem auto;">
                    <i class="fas fa-hourglass-half"></i>
                </div>
                <div class="stat-value" style="color:#ffc107;">@(((List<string>)ViewBag.PendingMigrations).Count)</div>
                <div class="stat-label">Pending Migrations</div>
            </div>
        </div>

        <!-- Pending Migrations -->
        @if (((List<string>)ViewBag.PendingMigrations).Count > 0)
        {
            <h2 class="section-title" style="color:#ffc107;"><i class="fas fa-exclamation-triangle"></i> Pending Migrations</h2>
            <div style="background:rgba(255,193,7,0.1); border:1px solid rgba(255,193,7,0.3); border-radius:20px; padding:1.5rem; margin-bottom:2rem;">
                @foreach (var migration in (List<string>)ViewBag.PendingMigrations)
                {
                    <div style="display:flex; align-items:center; gap:1rem; padding:0.75rem 0; border-bottom:1px solid rgba(255,255,255,0.05);">
                        <i class="fas fa-clock" style="color:#ffc107;"></i>
                        <span style="color:rgba(255,255,255,0.8); font-family:monospace;">@migration</span>
                        <span style="background:rgba(255,193,7,0.2); color:#ffc107; padding:0.2rem 0.6rem; border-radius:50px; font-size:0.75rem;">PENDING</span>
                    </div>
                }
                <div style="margin-top:1rem; background:rgba(0,0,0,0.3); border-radius:10px; padding:1rem; font-family:monospace;">
                    <p style="color:#ffc107; margin-bottom:0.25rem;"># Run this to apply pending migrations:</p>
                    <p style="color:#28a745;">dotnet ef database update</p>
                </div>
            </div>
        }

        <!-- Applied Migrations -->
        <h2 class="section-title"><i class="fas fa-history"></i> Applied Migrations</h2>
        @if (((List<string>)ViewBag.AppliedMigrations).Count == 0)
        {
            <div class="empty-state">
                <i class="fas fa-database" style="font-size:4rem; margin-bottom:1rem;"></i>
                <h3>No migrations applied yet</h3>
                <p>Run <code>dotnet ef database update</code> to apply migrations.</p>
            </div>
        }
        else
        {
            <div style="background:rgba(255,255,255,0.05); border-radius:20px; overflow:hidden;">
                <table style="width:100%; border-collapse:collapse;">
                    <thead>
                        <tr style="background:rgba(0,210,255,0.2);">
                            <th style="color:white; padding:1rem; text-align:left;">#</th>
                            <th style="color:white; padding:1rem; text-align:left;">Migration Name</th>
                            <th style="color:white; padding:1rem; text-align:left;">Status</th>
                        </tr>
                    </thead>
                    <tbody>
                        @{int i = 1;}
                        @foreach (var migration in (List<string>)ViewBag.AppliedMigrations)
                        {
                            <tr style="border-bottom:1px solid rgba(255,255,255,0.1);">
                                <td style="color:rgba(255,255,255,0.5); padding:1rem;">@i</td>
                                <td style="color:rgba(255,255,255,0.9); padding:1rem; font-family:monospace;">@migration</td>
                                <td style="padding:1rem;">
                                    <span style="background:rgba(40,167,69,0.2); color:#28a745; padding:0.25rem 0.75rem; border-radius:50px; font-size:0.75rem;">
                                        <i class="fas fa-check"></i> Applied
                                    </span>
                                </td>
                            </tr>
                            i++;
                        }
                    </tbody>
                </table>
            </div>
        }

        <!-- EF Core Info -->
        <h2 class="section-title" style="margin-top:2rem;"><i class="fas fa-info-circle"></i> About EF Core Migrations</h2>
        <div style="background:rgba(255,255,255,0.05); border-radius:20px; padding:2rem;">
            <p style="color:rgba(255,255,255,0.7); line-height:1.8;">
                Entity Framework Core Migrations allow the database schema to evolve over time as the application models change.
                Each migration captures a snapshot of model changes and generates SQL to update the database accordingly.
                This project uses a <strong style="color:#00d2ff;">Code-First</strong> approach — models in C# define the database schema.
            </p>
            <div style="margin-top:1.5rem; background:rgba(0,0,0,0.3); border-radius:10px; padding:1.5rem; font-family:monospace; line-height:2;">
                <p style="color:#ffc107;"># Create a new migration after model changes:</p>
                <p style="color:#28a745; margin-bottom:1rem;">dotnet ef migrations add &lt;MigrationName&gt;</p>
                <p style="color:#ffc107;"># Apply all pending migrations:</p>
                <p style="color:#28a745; margin-bottom:1rem;">dotnet ef database update</p>
                <p style="color:#ffc107;"># Roll back to a specific migration:</p>
                <p style="color:#28a745;">dotnet ef database update &lt;MigrationName&gt;</p>
            </div>
        </div>
    </div>
</body>
</html>
