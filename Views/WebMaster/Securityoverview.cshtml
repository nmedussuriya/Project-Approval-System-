@{
    Layout = null;
    ViewData["Title"] = "Security Overview | PAS";
}
@model List<PAS_Full_System.Controllers.UserSecurityInfo>

<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>@ViewData["Title"]</title>
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700;800&display=swap" rel="stylesheet">
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.0.0/css/all.min.css">
    <link rel="stylesheet" href="~/css/site.css">
</head>
<body>
    <nav class="glass-nav">
        <div class="nav-container">
            <div class="logo"><i class="fas fa-server"></i><span>PAS | WebMaster Portal</span></div>
            <div class="user-info">
                <a href="/Auth/Logout" style="color:white; background:rgba(255,255,255,0.2); padding:8px 20px; border-radius:25px;">
                    <i class="fas fa-sign-out-alt"></i> Logout
                </a>
            </div>
        </div>
    </nav>

    <div class="main-container">
        <a href="/WebMaster/Dashboard" style="color:#00d2ff; text-decoration:none; display:inline-block; margin-bottom:1rem;">
            <i class="fas fa-arrow-left"></i> Back to Dashboard
        </a>

        @if (TempData["Success"] != null)
        {
            <div class="alert-success"><i class="fas fa-check-circle"></i> @TempData["Success"]</div>
        }
        @if (TempData["Error"] != null)
        {
            <div style="background:rgba(220,53,69,0.2); border:1px solid #dc3545; color:#dc3545; padding:1rem; border-radius:10px; margin-bottom:1rem; text-align:center;">
                <i class="fas fa-exclamation-circle"></i> @TempData["Error"]
            </div>
        }

        <div class="welcome-card">
            <h1 class="welcome-title"><i class="fas fa-lock"></i> Security Overview</h1>
            <p class="welcome-subtitle">Monitor user lockout status, failed login attempts, and access control</p>
        </div>

        <!-- Summary -->
        <div class="stats-grid" style="grid-template-columns: repeat(3, 1fr); margin-bottom:2rem;">
            <div class="stat-card" style="text-align:center;">
                <div class="stat-icon" style="margin:0 auto 1rem auto;"><i class="fas fa-users"></i></div>
                <div class="stat-value">@Model.Count</div>
                <div class="stat-label">Total Users</div>
            </div>
            <div class="stat-card" style="text-align:center;">
                <div class="stat-icon" style="background:linear-gradient(135deg,#dc3545,#c82333); margin:0 auto 1rem auto;">
                    <i class="fas fa-user-lock"></i>
                </div>
                <div class="stat-value" style="color:#dc3545;">@Model.Count(u => u.LockoutEnd.HasValue && u.LockoutEnd > DateTime.Now)</div>
                <div class="stat-label">Locked Out Users</div>
            </div>
            <div class="stat-card" style="text-align:center;">
                <div class="stat-icon" style="background:linear-gradient(135deg,#ffc107,#fd7e14); margin:0 auto 1rem auto;">
                    <i class="fas fa-exclamation-triangle"></i>
                </div>
                <div class="stat-value" style="color:#ffc107;">@Model.Count(u => u.AccessFailedCount > 0)</div>
                <div class="stat-label">Failed Login Attempts</div>
            </div>
        </div>

        <!-- Users Security Table -->
        <h2 class="section-title"><i class="fas fa-table"></i> User Security Status</h2>
        <div style="background:rgba(255,255,255,0.05); border-radius:20px; overflow:hidden;">
            <table style="width:100%; border-collapse:collapse;">
                <thead>
                    <tr style="background:rgba(0,210,255,0.2);">
                        <th style="color:white; padding:1rem; text-align:left;">User</th>
                        <th style="color:white; padding:1rem; text-align:left;">Role</th>
                        <th style="color:white; padding:1rem; text-align:left;">Failed Logins</th>
                        <th style="color:white; padding:1rem; text-align:left;">Status</th>
                        <th style="color:white; padding:1rem; text-align:left;">Action</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var user in Model)
                    {
                        var isLocked = user.LockoutEnd.HasValue && user.LockoutEnd > DateTime.Now;
                        <tr style="border-bottom:1px solid rgba(255,255,255,0.1);">
                            <td style="padding:1rem;">
                                <div style="color:white; font-weight:600;">@user.FullName</div>
                                <div style="color:rgba(255,255,255,0.5); font-size:0.85rem;">@user.Email</div>
                            </td>
                            <td style="padding:1rem;">
                                <span style="background:rgba(0,210,255,0.2); color:#00d2ff; padding:0.25rem 0.75rem; border-radius:50px; font-size:0.8rem;">
                                    @user.Role
                                </span>
                            </td>
                            <td style="padding:1rem;">
                                @if (user.AccessFailedCount > 0)
                                {
                                    <span style="color:#ffc107; font-weight:600;">@user.AccessFailedCount</span>
                                }
                                else
                                {
                                    <span style="color:rgba(255,255,255,0.4);">0</span>
                                }
                            </td>
                            <td style="padding:1rem;">
                                @if (isLocked)
                                {
                                    <span style="background:rgba(220,53,69,0.2); color:#dc3545; padding:0.25rem 0.75rem; border-radius:50px; font-size:0.8rem;">
                                        <i class="fas fa-lock"></i> Locked
                                    </span>
                                }
                                else
                                {
                                    <span style="background:rgba(40,167,69,0.2); color:#28a745; padding:0.25rem 0.75rem; border-radius:50px; font-size:0.8rem;">
                                        <i class="fas fa-unlock"></i> Active
                                    </span>
                                }
                            </td>
                            <td style="padding:1rem;">
                                @if (isLocked)
                                {
                                    <form method="post" action="/WebMaster/UnlockUser" style="display:inline;">
                                        @Html.AntiForgeryToken()
                                        <input type="hidden" name="userId" value="@user.UserId" />
                                        <button type="submit" style="background:rgba(40,167,69,0.2); border:1px solid #28a745; color:#28a745; padding:0.4rem 1rem; border-radius:25px; cursor:pointer;">
                                            <i class="fas fa-unlock"></i> Unlock
                                        </button>
                                    </form>
                                }
                                else
                                {
                                    <form method="post" action="/WebMaster/LockUser" style="display:inline;"
                                          onsubmit="return confirm('Lock out @user.Email?');">
                                        @Html.AntiForgeryToken()
                                        <input type="hidden" name="userId" value="@user.UserId" />
                                        <button type="submit" style="background:rgba(220,53,69,0.2); border:1px solid #dc3545; color:#dc3545; padding:0.4rem 1rem; border-radius:25px; cursor:pointer;">
                                            <i class="fas fa-lock"></i> Lock
                                        </button>
                                    </form>
                                }
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>

        <!-- RBAC Rules Info -->
        <h2 class="section-title" style="margin-top:2rem;"><i class="fas fa-shield-alt"></i> Access Control Rules</h2>
        <div style="background:rgba(255,255,255,0.05); border-radius:20px; padding:2rem;">
            <div style="display:grid; grid-template-columns: repeat(2, 1fr); gap:1rem;">
                <div style="background:rgba(40,167,69,0.1); border-radius:15px; padding:1rem;">
                    <p style="color:#28a745; font-weight:600; margin-bottom:0.5rem;"><i class="fas fa-user-graduate"></i> Student</p>
                    <p style="color:rgba(255,255,255,0.6); font-size:0.85rem;">Can only access /Student/* routes</p>
                </div>
                <div style="background:rgba(0,210,255,0.1); border-radius:15px; padding:1rem;">
                    <p style="color:#00d2ff; font-weight:600; margin-bottom:0.5rem;"><i class="fas fa-chalkboard-teacher"></i> Supervisor</p>
                    <p style="color:rgba(255,255,255,0.6); font-size:0.85rem;">Can only access /Supervisor/* routes</p>
                </div>
                <div style="background:rgba(220,53,69,0.1); border-radius:15px; padding:1rem;">
                    <p style="color:#dc3545; font-weight:600; margin-bottom:0.5rem;"><i class="fas fa-user-cog"></i> Admin</p>
                    <p style="color:rgba(255,255,255,0.6); font-size:0.85rem;">Can only access /Admin/* routes</p>
                </div>
                <div style="background:rgba(255,193,7,0.1); border-radius:15px; padding:1rem;">
                    <p style="color:#ffc107; font-weight:600; margin-bottom:0.5rem;"><i class="fas fa-user-shield"></i> WebMaster</p>
                    <p style="color:rgba(255,255,255,0.6); font-size:0.85rem;">Can only access /WebMaster/* routes</p>
                </div>
            </div>
        </div>
    </div>
</body>
</html>