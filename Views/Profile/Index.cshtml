@model PAS_Full_System.Models.ApplicationUser

@{
    Layout = null;
    ViewData["Title"] = "My Profile";
    var role = ViewBag.Role as string;
    var researchAreas = ViewBag.ResearchAreas as List<string>;
}

<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>@ViewData["Title"]</title>
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700;800&display=swap" rel="stylesheet">
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.0.0/css/all.min.css">
    <style>
        * {
            margin: 0;
            padding: 0;
            box-sizing: border-box;
        }

        body {
            font-family: 'Inter', sans-serif;
            background: linear-gradient(135deg, #0b0f2f, #1c1f4a, #2b2d6e);
            min-height: 100vh;
            display: flex;
            justify-content: center;
            align-items: center;
            color: white;
        }

        .profile-wrapper {
            width: 100%;
            display: flex;
            justify-content: center;
            align-items: center;
            padding: 30px;
        }

        .profile-card {
            width: 100%;
            max-width: 520px;
            background: rgba(255, 255, 255, 0.08);
            backdrop-filter: blur(12px);
            border-radius: 24px;
            padding: 35px 30px;
            border: 1px solid rgba(255, 255, 255, 0.12);
            box-shadow: 0 12px 35px rgba(0, 0, 0, 0.25);
        }

        .profile-header {
            text-align: center;
            margin-bottom: 30px;
        }

        .profile-avatar {
            width: 100px;
            height: 100px;
            margin: 0 auto 20px;
            border-radius: 50%;
            background: linear-gradient(135deg, #00d2ff, #3a7bd5);
            display: flex;
            align-items: center;
            justify-content: center;
            font-size: 2.5rem;
        }

        .profile-title {
            font-size: 2.2rem;
            font-weight: 700;
            margin-bottom: 8px;
        }

        .profile-role {
            color: #00d2ff;
            font-size: 1.1rem;
            font-weight: 600;
        }

        .profile-info {
            display: grid;
            grid-template-columns: 1fr 1.5fr;
            gap: 18px 20px;
            margin-top: 25px;
            align-items: center;
        }

        .label {
            font-weight: 600;
            color: #d1d5db;
        }

        .value {
            color: white;
            word-break: break-word;
        }

        .back-btn {
            display: inline-block;
            margin-top: 30px;
            padding: 12px 24px;
            border-radius: 30px;
            background: linear-gradient(135deg, #00d2ff, #3a7bd5);
            color: white;
            text-decoration: none;
            font-weight: 600;
            transition: 0.3s ease;
        }

            .back-btn:hover {
                opacity: 0.9;
                transform: translateY(-2px);
            }

        @@media (max-width: 600px) {
            .profile-card {
                padding: 25px 20px;
            }

            .profile-title {
                font-size: 1.8rem;
            }

            .profile-info {
                grid-template-columns: 1fr;
            }
        }
    </style>
</head>
<body>
    <div class="profile-wrapper">
        <div class="profile-card">
            <div class="profile-header">
                <div class="profile-avatar">
                    <i class="fas fa-user"></i>
                </div>
                <div class="profile-title">@Model.FullName</div>
                <div class="profile-role">@role</div>
            </div>

            <div class="profile-info">
                <div class="label">Full Name</div>
                <div class="value">@Model.FullName</div>

                <div class="label">Email</div>
                <div class="value">@Model.Email</div>

                @if (role == "Supervisor")
                {
                    <div class="label">Research Areas</div>
                    <div class="value">
                        @if (researchAreas != null && researchAreas.Any())
                        {
                            @string.Join(", ", researchAreas)
                        }
                        else
                        {
                            <text>Not specified</text>
                        }
                    </div>
                }
                else
                {
                    <div class="label">Department</div>
                    <div class="value">@(!string.IsNullOrEmpty(Model.Department) ? Model.Department : "N/A")</div>
                }

                @if (role == "Student")
                {
                    <div class="label">Student ID</div>
                    <div class="value">@(!string.IsNullOrEmpty(Model.StudentId) ? Model.StudentId : "N/A")</div>
                }

                <div class="label">Phone Number</div>
                <div class="value">@(!string.IsNullOrEmpty(Model.PhoneNumber) ? Model.PhoneNumber : "N/A")</div>

                <div class="label">Created At</div>
                <div class="value">@Model.CreatedAt.ToString("dd MMM yyyy")</div>
            </div>

            <a href="javascript:history.back()" class="back-btn">
                <i class="fas fa-arrow-left"></i> Back
            </a>
        </div>
    </div>
</body>
</html>