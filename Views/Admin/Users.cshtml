@{
    Layout = null;
    ViewData["Title"] = "User Management | Admin";
}
@model List<PAS_Full_System.Models.ApplicationUser>

<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>@ViewData["Title"]</title>

    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700;800&display=swap" rel="stylesheet">
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.0.0/css/all.min.css">

    <style>
        * {
            margin: 0;
            padding: 0;
            box-sizing: border-box;
        }

        body {
            font-family: 'Inter', sans-serif;
            background: linear-gradient(135deg, #0f0c29, #302b63, #24243e);
            min-height: 100vh;
        }

        .glass-nav {
            background: rgba(255, 255, 255, 0.1);
            backdrop-filter: blur(10px);
            padding: 1rem 2rem;
        }

        .nav-container {
            max-width: 1400px;
            margin: auto;
            display: flex;
            justify-content: space-between;
            align-items: center;
            color: white;
        }

        .main-container {
            max-width: 1400px;
            margin: 2rem auto;
            padding: 0 2rem;
        }

        .welcome-title {
            font-size: 2rem;
            color: #00d2ff;
            margin-bottom: 1rem;
        }

        .btn-primary {
            background: linear-gradient(135deg, #00d2ff, #3a7bd5);
            color: white;
            padding: 0.7rem 1.4rem;
            border-radius: 30px;
            text-decoration: none;
        }

        table {
            width: 100%;
            margin-top: 1.5rem;
            background: rgba(255,255,255,0.05);
            border-radius: 20px;
            overflow: hidden;
        }

        th {
            background: rgba(0,210,255,0.2);
            padding: 1rem;
            color: white;
        }

        td {
            padding: 1rem;
            color: rgba(255,255,255,0.8);
        }

        .btn-edit {
            background: #ffc107;
            padding: 5px 10px;
            border-radius: 5px;
            text-decoration: none;
            color: black;
            margin-right: 5px;
        }

        .btn-delete {
            background: #dc3545;
            padding: 5px 10px;
            border-radius: 5px;
            color: white;
            border: none;
            cursor: pointer;
        }

        .alert-success {
            background: rgba(40,167,69,0.2);
            padding: 10px;
            border-radius: 10px;
            margin-bottom: 10px;
            color: #28a745;
        }
    </style>
</head>

<body>

    <div class="glass-nav">
        <div class="nav-container">
            <h2><i class="fas fa-users"></i> User Management</h2>
            <a href="/Admin/Dashboard" class="btn-primary">Back</a>
        </div>
    </div>

    <div class="main-container">

        @if (TempData["Success"] != null)
        {
            <div class="alert-success">@TempData["Success"]</div>
        }

        <h1 class="welcome-title">All Users</h1>

        <table>
            <thead>
                <tr>
                    <th>Email</th>
                    <th>Full Name</th>
                    <th>Department</th>
                    <th>Role</th>
                    <th>Actions</th>
                </tr>
            </thead>

            <tbody>
                @foreach (var user in Model)
                {
                    <tr>
                        <td>@user.Email</td>
                        <td>@user.FullName</td>
                        <td>@user.Department</td>
                        <td>@ViewBag.UserRoles[user.Id]</td>

                        <td>
                            <a href="/Admin/EditUser/@user.Id" class="btn-edit">Edit</a>

                            <!-- ✅ FIXED DELETE -->
                            <form asp-action="DeleteUser"
                                  asp-controller="Admin"
                                  method="post"
                                  style="display:inline;">

                                @Html.AntiForgeryToken()

                                <input type="hidden" name="id" value="@user.Id" />

                                <button type="submit"
                                        class="btn-delete"
                                        onclick="return confirm('Are you sure you want to delete this user?');">
                                    Delete
                                </button>

                            </form>
                        </td>
                    </tr>
                }
            </tbody>
        </table>

    </div>

</body>
</html>