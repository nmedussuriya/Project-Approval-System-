@model PAS_Full_System.Models.SupervisorAvailability

@{
    Layout = null;
    ViewData["Title"] = "Create Time Slot | PAS";
}

<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>@ViewData["Title"]</title>
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700;800&display=swap" rel="stylesheet">
    <link rel="stylesheet" href="~/css/site.css">
    <style>
        body {
            margin: 0;
            font-family: 'Inter', sans-serif;
            background: linear-gradient(135deg, #0f0c29, #302b63, #24243e);
            color: white;
            min-height: 100vh;
        }

        .main-container {
            width: 100%;
            max-width: 1100px;
            margin: 0 auto;
            padding: 2rem 2rem 4rem 2rem;
        }

        .back-link {
            color: #00d2ff;
            text-decoration: none;
            display: inline-block;
            margin-bottom: 1.5rem;
            font-weight: 600;
        }

        .page-card {
            background: linear-gradient(135deg, rgba(0, 210, 255, 0.12), rgba(58, 123, 213, 0.12));
            backdrop-filter: blur(10px);
            border-radius: 30px;
            padding: 2rem;
            margin-bottom: 2rem;
            border: 1px solid rgba(255, 255, 255, 0.15);
        }

        .page-title {
            font-size: 2.2rem;
            font-weight: 700;
            color: #00d2ff;
            margin-bottom: 0.5rem;
        }

        .page-subtitle {
            color: rgba(255, 255, 255, 0.75);
            font-size: 1rem;
        }

        .form-box {
            background: rgba(255, 255, 255, 0.06);
            backdrop-filter: blur(10px);
            border-radius: 24px;
            padding: 2rem;
            border: 1px solid rgba(255, 255, 255, 0.1);
            max-width: 850px;
        }

        .form-group {
            margin-bottom: 1.5rem;
        }

        .form-label {
            display: block;
            margin-bottom: 0.6rem;
            font-weight: 600;
            color: white;
            font-size: 1rem;
        }

        .form-control {
            width: 100%;
            box-sizing: border-box;
            padding: 14px 16px;
            border-radius: 16px;
            border: 1px solid rgba(255,255,255,0.15);
            background: rgba(255,255,255,0.92);
            color: #111;
            font-size: 1rem;
            outline: none;
        }

            .form-control:focus {
                border-color: #00d2ff;
                box-shadow: 0 0 0 3px rgba(0, 210, 255, 0.15);
            }

        .text-danger {
            color: #ff6b6b;
            font-size: 0.9rem;
            margin-top: 0.4rem;
            display: block;
        }

        .validation-summary-errors,
        .validation-summary-valid {
            margin-bottom: 1rem;
        }

            .validation-summary-errors ul {
                margin: 0;
                padding-left: 1.2rem;
                color: #ff6b6b;
            }

        .btn-row {
            display: flex;
            gap: 1rem;
            margin-top: 1.5rem;
            flex-wrap: wrap;
        }

        .btn-action {
            padding: 0.95rem 1.6rem;
            border-radius: 50px;
            font-weight: 600;
            text-decoration: none;
            transition: all 0.3s ease;
            display: inline-flex;
            align-items: center;
            gap: 10px;
            border: none;
            cursor: pointer;
            font-size: 0.95rem;
        }

        .btn-primary {
            background: linear-gradient(135deg, #00d2ff, #3a7bd5);
            color: white;
        }

        .btn-secondary {
            background: rgba(255, 255, 255, 0.12);
            color: white;
            border: 1px solid rgba(255, 255, 255, 0.15);
        }

        .btn-action:hover {
            transform: translateY(-2px);
        }
    </style>
</head>
<body>
    <div class="main-container">
        <a href="/Availability/MySlots" class="back-link">← Back to My Slots</a>

        <div class="page-card">
            <h1 class="page-title">Create Time Slot</h1>
            <p class="page-subtitle">Add your available meeting time so matched students can book it after identity reveal.</p>
        </div>

        <div class="form-box">
            <form asp-action="CreateSlot" method="post">
                @Html.AntiForgeryToken()
                <div asp-validation-summary="All" class="text-danger"></div>

                <div class="form-group">
                    <label asp-for="StartTime" class="form-label">Start Time</label>
                    <input asp-for="StartTime" class="form-control" type="datetime-local" />
                    <span asp-validation-for="StartTime" class="text-danger"></span>
                </div>

                <div class="form-group">
                    <label asp-for="EndTime" class="form-label">End Time</label>
                    <input asp-for="EndTime" class="form-control" type="datetime-local" />
                    <span asp-validation-for="EndTime" class="text-danger"></span>
                </div>

                <div class="btn-row">
                    <button type="submit" class="btn-action btn-primary">Save Slot</button>
                    <a href="/Availability/MySlots" class="btn-action btn-secondary">Cancel</a>
                </div>
            </form>
        </div>
    </div>
</body>
</html>