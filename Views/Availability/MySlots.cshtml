@model IEnumerable<PAS_Full_System.Models.SupervisorAvailability>

@{
    Layout = null;
    ViewData["Title"] = "My Available Time Slots | PAS";
}

<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>@ViewData["Title"]</title>
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700;800&display=swap" rel="stylesheet">
    <link rel="stylesheet" href="~/css/site.css">
    <style>
        body {
            margin: 0;
            font-family: 'Inter', sans-serif;
            background: linear-gradient(135deg, #0f0c29, #302b63, #24243e);
            color: white;
            min-height: 100vh;
        }

        .main-container {
            width: 100%;
            max-width: 1200px;
            margin: 0 auto;
            padding: 2rem 2rem 4rem 2rem;
        }

        .back-link {
            color: #00d2ff;
            text-decoration: none;
            display: inline-block;
            margin-bottom: 1.5rem;
            font-weight: 600;
        }

        .page-card {
            background: linear-gradient(135deg, rgba(0, 210, 255, 0.12), rgba(58, 123, 213, 0.12));
            backdrop-filter: blur(10px);
            border-radius: 30px;
            padding: 2rem;
            margin-bottom: 2rem;
            border: 1px solid rgba(255, 255, 255, 0.15);
        }

        .page-title {
            font-size: 2.2rem;
            font-weight: 700;
            color: #00d2ff;
            margin-bottom: 0.5rem;
        }

        .page-subtitle {
            color: rgba(255, 255, 255, 0.75);
            font-size: 1rem;
        }

        .table-box {
            background: rgba(255, 255, 255, 0.06);
            backdrop-filter: blur(10px);
            border-radius: 24px;
            padding: 2rem;
            border: 1px solid rgba(255, 255, 255, 0.1);
        }

        .btn-action {
            padding: 0.95rem 1.6rem;
            border-radius: 50px;
            font-weight: 600;
            text-decoration: none;
            transition: all 0.3s ease;
            display: inline-flex;
            align-items: center;
            gap: 10px;
            border: none;
            cursor: pointer;
            font-size: 0.95rem;
            margin-bottom: 1.5rem;
        }

        .btn-primary {
            background: linear-gradient(135deg, #00d2ff, #3a7bd5);
            color: white;
        }

        .btn-action:hover {
            transform: translateY(-2px);
        }

        .slots-table {
            width: 100%;
            border-collapse: collapse;
            overflow: hidden;
            border-radius: 20px;
        }

            .slots-table th {
                background: rgba(0, 210, 255, 0.18);
                color: white;
                padding: 1rem;
                text-align: left;
            }

            .slots-table td {
                padding: 1rem;
                color: rgba(255, 255, 255, 0.85);
                border-bottom: 1px solid rgba(255, 255, 255, 0.08);
                vertical-align: top;
            }

        .status-badge {
            padding: 0.35rem 0.85rem;
            border-radius: 50px;
            font-size: 0.8rem;
            font-weight: 600;
            display: inline-block;
        }

        .status-available {
            background: rgba(40, 167, 69, 0.2);
            color: #28a745;
        }

        .status-booked {
            background: rgba(255, 193, 7, 0.2);
            color: #ffc107;
        }

        .booking-info {
            margin-top: 8px;
            color: rgba(255,255,255,0.8);
            font-size: 0.9rem;
            line-height: 1.6;
        }

        .empty-state {
            text-align: center;
            padding: 3rem;
            background: rgba(255, 255, 255, 0.04);
            border-radius: 20px;
            color: rgba(255, 255, 255, 0.65);
        }
    </style>
</head>
<body>
    <div class="main-container">
        <a href="/Supervisor/Dashboard" class="back-link">← Back to Dashboard</a>

        <div class="page-card">
            <h1 class="page-title">My Available Time Slots</h1>
            <p class="page-subtitle">Manage your available meeting times for matched students.</p>
        </div>

        <div class="table-box">
            <a asp-action="CreateSlot" class="btn-action btn-primary">Add New Slot</a>

            @if (!Model.Any())
            {
                <div class="empty-state">
                    <h3>No time slots yet</h3>
                    <p>Click “Add New Slot” to create your first available meeting time.</p>
                </div>
            }
            else
            {
                <table class="slots-table">
                    <thead>
                        <tr>
                            <th>Start Time</th>
                            <th>End Time</th>
                            <th>Status / Booking Details</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var slot in Model)
                        {
                            var booking = slot.MeetingBookings?.FirstOrDefault();

                            <tr>
                                <td>@slot.StartTime.ToString("MMM dd, yyyy hh:mm tt")</td>
                                <td>@slot.EndTime.ToString("MMM dd, yyyy hh:mm tt")</td>
                                <td>
                                    @if (slot.IsBooked)
                                    {
                                        <span class="status-badge status-booked">Booked</span>

                                        <div class="booking-info">
                                            <div>👤 @(booking?.Student?.FullName ?? "Student")</div>
                                            <div>📄 @(booking?.Project?.Title ?? "Project")</div>
                                        </div>
                                    }
                                    else
                                    {
                                        <span class="status-badge status-available">Available</span>
                                    }
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            }
        </div>
    </div>
</body>
</html>
     