@{
    Layout = null;
    ViewData["Title"] = "Project Approval System";
}

<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>@ViewData["Title"]</title>
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700;800&display=swap" rel="stylesheet">
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.0.0/css/all.min.css">
    <style>
        * {
            margin: 0;
            padding: 0;
            box-sizing: border-box;
        }

        body {
            font-family: 'Inter', sans-serif;
            background: linear-gradient(135deg, #0f0c29, #302b63, #24243e);
            min-height: 100vh;
        }

        .main-container {
            max-width: 1400px;
            margin: 0 auto;
            padding: 2rem;
            min-height: 100vh;
            display: flex;
            flex-direction: column;
            justify-content: center;
        }

        .hero-section {
            background: linear-gradient(135deg, rgba(0, 210, 255, 0.15), rgba(58, 123, 213, 0.15));
            backdrop-filter: blur(10px);
            border-radius: 30px;
            padding: 4rem 2rem;
            margin-bottom: 3rem;
            text-align: center;
            border: 1px solid rgba(255, 255, 255, 0.2);
        }

        .hero-title {
            font-size: 3rem;
            font-weight: 800;
            background: linear-gradient(135deg, #00d2ff, #3a7bd5);
            -webkit-background-clip: text;
            -webkit-text-fill-color: transparent;
            margin-bottom: 1rem;
        }

        .hero-subtitle {
            font-size: 1.2rem;
            color: rgba(255, 255, 255, 0.8);
            margin-bottom: 2rem;
        }

        .role-buttons {
            display: flex;
            gap: 1.5rem;
            justify-content: center;
            flex-wrap: wrap;
        }

        .role-btn {
            padding: 1rem 2.5rem;
            border-radius: 50px;
            font-size: 1.1rem;
            font-weight: 600;
            text-decoration: none;
            transition: all 0.3s ease;
            display: inline-flex;
            align-items: center;
            gap: 10px;
        }

        .btn-student {
            background: linear-gradient(135deg, #28a745, #20c997);
            color: white;
        }

        .btn-supervisor {
            background: linear-gradient(135deg, #00d2ff, #3a7bd5);
            color: white;
        }

        .btn-admin {
            background: linear-gradient(135deg, #dc3545, #c82333);
            color: white;
        }

        .role-btn:hover {
            transform: translateY(-3px);
            box-shadow: 0 10px 30px rgba(0, 0, 0, 0.3);
        }

        .features-grid {
            display: grid;
            grid-template-columns: repeat(3, 1fr);
            gap: 2rem;
            margin-top: 2rem;
        }

        .feature-card {
            background: rgba(255, 255, 255, 0.05);
            backdrop-filter: blur(10px);
            border-radius: 20px;
            padding: 2rem;
            text-align: center;
            border: 1px solid rgba(255, 255, 255, 0.1);
            transition: all 0.3s ease;
        }

            .feature-card:hover {
                transform: translateY(-5px);
                border-color: #00d2ff;
            }

        .feature-icon {
            font-size: 3rem;
            margin-bottom: 1rem;
        }

        .feature-title {
            font-size: 1.3rem;
            font-weight: 600;
            color: white;
            margin-bottom: 0.5rem;
        }

        .feature-desc {
            color: rgba(255, 255, 255, 0.6);
            line-height: 1.5;
        }

        footer {
            text-align: center;
            margin-top: 3rem;
            padding: 1.5rem;
            color: rgba(255, 255, 255, 0.4);
            border-top: 1px solid rgba(255, 255, 255, 0.1);
        }
    </style>
</head>
<body>
    <div class="main-container">
        <div class="hero-section">
            <h1 class="hero-title">Project Approval System</h1>
            <p class="hero-subtitle">Blind Matching Platform for Student Research Projects</p>
            <div class="role-buttons">
                <a href="/Identity/Account/Login?returnUrl=/Student/Dashboard" class="role-btn btn-student">
                    <i class="fas fa-user-graduate"></i> Student Login
                </a>
                <a href="/Identity/Account/Login?returnUrl=/Supervisor/Dashboard" class="role-btn btn-supervisor">
                    <i class="fas fa-chalkboard-user"></i> Supervisor Login
                </a>
                <a href="/Identity/Account/Login?returnUrl=/Admin/Dashboard" class="role-btn btn-admin">
                    <i class="fas fa-user-cog"></i> Admin Login
                </a>
            </div>
        </div>

        <div class="features-grid">
            <div class="feature-card">
                <div class="feature-icon">📝</div>
                <h3 class="feature-title">For Students</h3>
                <p class="feature-desc">Submit project proposals, track status, and get matched with ideal supervisors.</p>
            </div>
            <div class="feature-card">
                <div class="feature-icon">👨‍🏫</div>
                <h3 class="feature-title">For Supervisors</h3>
                <p class="feature-desc">Review anonymous proposals. Student identities remain hidden until you confirm.</p>
            </div>
            <div class="feature-card">
                <div class="feature-icon">⚙️</div>
                <h3 class="feature-title">For Admins</h3>
                <p class="feature-desc">Manage users, research areas, and oversee the matching process.</p>
            </div>
        </div>

        <footer>
            <p>© @DateTime.Now.Year - PAS | Project Approval System - Blind Matching Platform</p>
        </footer>
    </div>
</body>
</html>