@page
@{
    Layout = null;
    ViewData["Title"] = "Register | PAS";
}

<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>@ViewData["Title"]</title>
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700;800&display=swap" rel="stylesheet">
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.0.0/css/all.min.css">
    <style>
        * {
            margin: 0;
            padding: 0;
            box-sizing: border-box;
        }

        body {
            font-family: 'Inter', sans-serif;
            background: linear-gradient(135deg, #0f0c29, #302b63, #24243e);
            min-height: 100vh;
            display: flex;
            align-items: center;
            justify-content: center;
            padding: 2rem;
        }

        .register-container {
            max-width: 500px;
            width: 100%;
            margin: 0 auto;
        }

        .register-card {
            background: rgba(255, 255, 255, 0.1);
            backdrop-filter: blur(10px);
            border-radius: 30px;
            padding: 2.5rem;
            border: 1px solid rgba(255, 255, 255, 0.2);
            box-shadow: 0 20px 40px rgba(0, 0, 0, 0.3);
        }

        .logo {
            text-align: center;
            margin-bottom: 2rem;
        }

            .logo i {
                font-size: 3rem;
                background: linear-gradient(135deg, #00d2ff, #3a7bd5);
                -webkit-background-clip: text;
                -webkit-text-fill-color: transparent;
            }

            .logo h1 {
                color: white;
                font-size: 1.8rem;
                margin-top: 0.5rem;
            }

            .logo p {
                color: rgba(255, 255, 255, 0.6);
            }

        .form-group {
            margin-bottom: 1.2rem;
        }

        label {
            color: rgba(255, 255, 255, 0.8);
            display: block;
            margin-bottom: 0.5rem;
            font-weight: 500;
        }

        input, select {
            width: 100%;
            padding: 0.75rem 1rem;
            background: rgba(255, 255, 255, 0.1);
            border: 1px solid rgba(255, 255, 255, 0.2);
            border-radius: 15px;
            color: white;
            font-family: 'Inter', sans-serif;
            font-size: 1rem;
        }

            input:focus, select:focus {
                outline: none;
                border-color: #00d2ff;
            }

            input::placeholder {
                color: rgba(255, 255, 255, 0.4);
            }

        .radio-group {
            display: flex;
            gap: 2rem;
            align-items: center;
            margin-top: 0.5rem;
            flex-wrap: wrap;
        }

            .radio-group label {
                display: flex;
                align-items: center;
                gap: 0.5rem;
                font-weight: normal;
                margin-bottom: 0;
                cursor: pointer;
            }

            .radio-group input {
                width: auto;
                margin: 0;
                cursor: pointer;
            }

        .register-btn {
            width: 100%;
            background: linear-gradient(135deg, #00d2ff, #3a7bd5);
            color: white;
            padding: 0.75rem;
            border: none;
            border-radius: 50px;
            font-size: 1rem;
            font-weight: 600;
            cursor: pointer;
            margin-top: 1rem;
            transition: all 0.3s ease;
        }

            .register-btn:hover {
                transform: translateY(-2px);
                box-shadow: 0 10px 30px rgba(0, 210, 255, 0.3);
            }

        .login-link {
            text-align: center;
            margin-top: 1.5rem;
        }

            .login-link a {
                color: #00d2ff;
                text-decoration: none;
            }

            .login-link p {
                color: rgba(255, 255, 255, 0.6);
                margin-top: 0.5rem;
            }

        .error-message {
            background: rgba(220, 53, 69, 0.2);
            border: 1px solid #dc3545;
            color: #dc3545;
            padding: 0.75rem;
            border-radius: 10px;
            margin-bottom: 1rem;
            text-align: center;
        }

        #studentIdField {
            display: none;
        }

        #departmentField {
            display: block;
        }

        #supervisorResearchAreas {
            display: none;
        }

        .research-area-list {
            display: flex;
            flex-direction: column;
            gap: 0.7rem;
            margin-top: 0.7rem;
        }

        .research-area-item {
            display: flex;
            align-items: center;
            gap: 0.6rem;
            color: white;
            cursor: pointer;
        }

            .research-area-item input[type="checkbox"] {
                width: auto;
                margin: 0;
            }

        select option {
            background-color: white;
            color: black;
        }
    </style>
</head>
<body>
    <div class="register-container">
        <div class="register-card">
            <div class="logo">
                <i class="fas fa-user-plus"></i>
                <h1>Create Account</h1>
                <p>Join the Project Approval System</p>
            </div>

            @if (TempData["Error"] != null)
            {
                <div class="error-message">
                    <i class="fas fa-exclamation-triangle"></i> @TempData["Error"]
                </div>
            }

            <form method="post" action="/Auth/Register">
                <div class="form-group">
                    <label>Register as</label>
                    <div class="radio-group">
                        <label>
                            <input type="radio" name="Role" value="Student" checked onclick="toggleStudentId()" /> Student
                        </label>
                        <label>
                            <input type="radio" name="Role" value="Supervisor" onclick="toggleStudentId()" /> Supervisor
                        </label>
                        <label>
                            <input type="radio" name="Role" value="Admin" onclick="toggleStudentId()" /> Admin
                        </label>
                    </div>
                </div>

                <div class="form-group">
                    <label>Full Name</label>
                    <input name="FullName" placeholder="Enter your full name" required />
                </div>

                <div class="form-group">
                    <label>Email Address</label>
                    <input name="Email" type="email" placeholder="you@example.com" required />
                </div>

                <div class="form-group" id="departmentField">
                    <label>Department</label>
                    <select name="Department">
                        <option value="">Select Department</option>
                        <option>Computer Science</option>
                        <option>Information Technology</option>
                        <option>Software Engineering</option>
                        <option>Data Science</option>
                        <option>Cybersecurity</option>
                    </select>
                </div>

                <div class="form-group" id="studentIdField">
                    <label>Student ID</label>
                    <input name="StudentId" placeholder="e.g., STU-2024-001" />
                </div>

                <div class="form-group" id="supervisorResearchAreas">
                    <label>Select Research Areas</label>
                    <div class="research-area-list">
                        <label class="research-area-item">
                            <input type="checkbox" name="SelectedResearchAreas" value="1" />
                            Artificial Intelligence
                        </label>
                        <label class="research-area-item">
                            <input type="checkbox" name="SelectedResearchAreas" value="2" />
                            Web Development
                        </label>
                        <label class="research-area-item">
                            <input type="checkbox" name="SelectedResearchAreas" value="3" />
                            Cybersecurity
                        </label>
                        <label class="research-area-item">
                            <input type="checkbox" name="SelectedResearchAreas" value="4" />
                            Cloud Computing
                        </label>
                        <label class="research-area-item">
                            <input type="checkbox" name="SelectedResearchAreas" value="5" />
                            Mobile Development
                        </label>
                    </div>
                </div>

                <div class="form-group">
                    <label>Password</label>
                    <input name="Password" type="password" placeholder="Minimum 6 characters" required />
                </div>

                <div class="form-group">
                    <label>Confirm Password</label>
                    <input name="ConfirmPassword" type="password" placeholder="Confirm your password" required />
                </div>

                <button type="submit" class="register-btn">
                    <i class="fas fa-check-circle"></i> Register
                </button>
            </form>

            <div class="login-link">
                <p>Already have an account? <a href="/Identity/Account/Login">Login here</a></p>
                <p><a href="/">← Back to Home</a></p>
            </div>
        </div>
    </div>

    <script>
        function toggleStudentId() {
            var selectedRole = document.querySelector('input[name="Role"]:checked').value;
            var studentIdField = document.getElementById('studentIdField');
            var supervisorResearchAreas = document.getElementById('supervisorResearchAreas');
            var departmentField = document.getElementById('departmentField');

            if (selectedRole === 'Student') {
                studentIdField.style.display = "block";
                supervisorResearchAreas.style.display = "none";
                departmentField.style.display = "block";
            }
            else if (selectedRole === 'Supervisor') {
                studentIdField.style.display = "none";
                supervisorResearchAreas.style.display = "block";
                departmentField.style.display = "none";
            }
            else {
                studentIdField.style.display = "none";
                supervisorResearchAreas.style.display = "none";
                departmentField.style.display = "block";
            }
        }

        toggleStudentId();
    </script>
</body>
</html>